@model List<Paciente>

<h2>Pacientes</h2>
<a href="/Pacientes/Create" class="btn btn-primary mb-3">Agregar Paciente</a>

<table class="table table-striped">
    <thead>
        <tr><th>Id</th><th>Nombre Completo</th><th>Preguntas</th><th>Acciones</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.Name</td>
                <td>
                    @if (c.Preguntas != null && c.Preguntas.Count > 0)
                    {
                        <ul>
                            @foreach (var pregunta in c.Preguntas)
                            {
                                <li>@pregunta.Contenido</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span>No tiene preguntas.</span>
                    }
                </td>
                <td>
                    <a href="/Pacientes/Edit/@c.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a href="/Pacientes/Delete/@c.Id" class="btn btn-danger btn-sm"
                       onclick="return confirm('¿Seguro que quieres borrar este paciente?');">Borrar</a>
                </td>
                <td>
                    <a href="/Preguntas/Create?idPaciente=@c.Id" class="btn btn-info btn-sm">Agregar Pregunta</a>
                    <a href="/Preguntas/Edit?idPaciente=@c.Id" class="btn btn-info btn-sm">Editar Preguntas</a>
                </td>
                <td>
                    <a asp-controller="DiarioPaciente" asp-action="Index" asp-route-idPaciente="@c.Id" class="btn btn-info btn-sm">Ver Diarios</a>
                </td>
            </tr>
        }
    </tbody>
</table>