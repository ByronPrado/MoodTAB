@model WebConTablas.Models.Paciente
@using System.Text.Json;
@{
    ViewData["Title"] = "Detalles del Paciente";
}

<h2>Detalles de: @Model.Nombre</h2>
<hr />

<div>
    <h4>Información General</h4>
    <dl class="row">
        <!-- ... (Información general del paciente se mantiene igual) ... -->
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.ID_Paciente</dd>
        <dt class="col-sm-2">Diagnóstico</dt>
        <dd class="col-sm-10">@Model.Diagnostico</dd>
        <dt class="col-sm-2">Edad</dt>
        <dd class="col-sm-10">@Model.Edad</dd>
        <dt class="col-sm-2">Sexo</dt>
        <dd class="col-sm-10">@Model.Sexo</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        <dt class="col-sm-2">Teléfono</dt>
        <dd class="col-sm-10">@Model.Telefono</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Diarios Emocionales</h4>

    <!-- Contenedor para los gráficos -->
    <div class="row">
        <!-- Gráfico de Pasos -->
        @if (Model.DiariosEmocionales != null && Model.DiariosEmocionales.Any(d => d.Pasos.HasValue))
        {
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Gráfico de Pasos (Últimos 7 días)</h5>
                        <canvas id="pasosChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>
        }

        <!-- Gráfico Horas de Celular -->
        @if (Model.DiariosEmocionales != null && Model.DiariosEmocionales.Any(d => d.Horas_celular.HasValue))
        {
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Gráfico de Horas de Celular (Últimos 7 días)</h5>
                        <canvas id="celularChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>
        }

        <!-- Gráfico Horas Redes Sociales -->
        @if (Model.DiariosEmocionales != null && Model.DiariosEmocionales.Any(d => d.Horas_redes.HasValue))
        {
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Gráfico de Horas en Redes Sociales (Últimos 7 días)</h5>
                        <canvas id="redesChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>
        }

        <!-- ======================= INICIO: CUARTO GRÁFICO ESTADOS DE ÁNIMO ======================= -->
        @if (Model.DiariosEmocionales != null && Model.DiariosEmocionales.Any())
        {
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Distribución de Estados (Últimos 7 días)</h5>
                        <canvas id="estadosChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>
        }
        <!-- ======================= FIN: CUARTO GRÁFICO ESTADOS DE ÁNIMO ======================= -->
    </div>

    @if (Model.DiariosEmocionales != null && Model.DiariosEmocionales.Any())
    {
        <table class="table table-bordered table-striped">
            <!-- ... (La tabla de datos se mantiene igual) ... -->
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Emociones</th>
                    <th>Descripción</th>
                    <th>Pasos</th>
                    <th>Horas Celular</th>
                    <th>Horas Redes</th>
                    <th>Hora Dormida</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var d in Model.DiariosEmocionales.OrderByDescending(d => d.Fecha))
                {
                    <tr>
                        <td>@d.Fecha.ToShortDateString()</td>
                        @{
                            string emocionesStr = "N/A";
                            try
                            {
                                if (!string.IsNullOrEmpty(d.Emociones))
                                {
                                    var emocionesDict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, int>>(d.Emociones);
                                    emocionesStr = string.Join(", ", emocionesDict.Keys);
                                }
                            }
                            catch {}
                        }
                        <td>@emocionesStr</td>
                        <td>@d.Descripcion</td>
                        <td>@d.Pasos</td>
                        <td>@d.Horas_celular</td>
                        <td>@d.Horas_redes</td>
                        <td>@d.Hora_dormida</td>
                        <td>
                            <span class="badge 
                                @(d.Estado == "exitado" ? "bg-success" : d.Estado == "inhibido" ? "bg-danger" : "bg-secondary")">
                                @d.Estado
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No hay diarios emocionales registrados para este paciente.</p>
    }
</div>

<div class="mt-3">
    <a href="@Url.Action("Index", "Pacientes")" class="btn btn-secondary">Volver a la lista</a>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            // --- Bloque de C# para preparar TODOS los datos ---
            @{
                // Datos para el gráfico de pasos
                var diariosConPasos = Model.DiariosEmocionales.Where(d => d.Pasos.HasValue).OrderByDescending(d => d.Fecha).Take(7).OrderBy(d => d.Fecha).ToList();
                var labelsPasosList = diariosConPasos.Select(d => d.Fecha.ToString("dd/MM"));
                var dataPasosList = diariosConPasos.Select(d => d.Pasos.Value);

                // Datos para el gráfico de horas de celular
                var diariosConCelular = Model.DiariosEmocionales.Where(d => d.Horas_celular.HasValue).OrderByDescending(d => d.Fecha).Take(7).OrderBy(d => d.Fecha).ToList();
                var labelsCelularList = diariosConCelular.Select(d => d.Fecha.ToString("dd/MM"));
                var dataCelularList = diariosConCelular.Select(d => d.Horas_celular.Value);

                // Datos para el gráfico de horas en redes
                var diariosConRedes = Model.DiariosEmocionales.Where(d => d.Horas_redes.HasValue).OrderByDescending(d => d.Fecha).Take(7).OrderBy(d => d.Fecha).ToList();
                var labelsRedesList = diariosConRedes.Select(d => d.Fecha.ToString("dd/MM"));
                var dataRedesList = diariosConRedes.Select(d => d.Horas_redes.Value);

                // ======================= INICIO: DATOS PARA GRÁFICO DE ESTADOS =======================
                var ultimosSieteDiarios = Model.DiariosEmocionales.OrderByDescending(d => d.Fecha).Take(7).ToList();
                decimal totalRegistros = ultimosSieteDiarios.Count;
                decimal porcentajeInhibido = 0;
                decimal porcentajeExitado = 0;
                decimal porcentajeOtro = 0;

                if (totalRegistros > 0)
                {
                    decimal countInhibido = ultimosSieteDiarios.Count(d => d.Estado == "inhibido");
                    decimal countExitado = ultimosSieteDiarios.Count(d => d.Estado == "exitado");
                    
                    porcentajeInhibido = Math.Round((countInhibido / totalRegistros) * 100, 1);
                    porcentajeExitado = Math.Round((countExitado / totalRegistros) * 100, 1);
                    porcentajeOtro = 100 - porcentajeInhibido - porcentajeExitado;
                }

                var labelsEstadosList = new List<string> { "Inhibido", "Exitado", "Otro" };
                var dataEstadosList = new List<decimal> { porcentajeInhibido, porcentajeExitado, porcentajeOtro };
                // ======================= FIN: DATOS PARA GRÁFICO DE ESTADOS =======================
            }

            // --- Gráfico 1: Pasos (Barras) ---
            if (document.getElementById('pasosChart')) {
                // ... (código del gráfico 1 sin cambios)
                const chartLabelsPasos = @Html.Raw(Json.Serialize(labelsPasosList));
                const chartDataPasos = @Html.Raw(Json.Serialize(dataPasosList));
                const ctxPasos = document.getElementById('pasosChart').getContext('2d');
                new Chart(ctxPasos, { type: 'bar', data: { labels: chartLabelsPasos, datasets: [{ label: 'Pasos realizados', data: chartDataPasos, backgroundColor: 'rgba(54, 162, 235, 0.6)', borderColor: 'rgba(54, 162, 235, 1)', borderWidth: 1 }] }, options: { scales: { y: { beginAtZero: true, title: { display: true, text: 'Cantidad de Pasos' } } }, plugins: { legend: { display: false } } } });
            }

            // --- Gráfico 2: Horas de Celular (Líneas) ---
            if (document.getElementById('celularChart')) {
                // ... (código del gráfico 2 sin cambios)
                const chartLabelsCelular = @Html.Raw(Json.Serialize(labelsCelularList));
                const chartDataCelular = @Html.Raw(Json.Serialize(dataCelularList));
                const ctxCelular = document.getElementById('celularChart').getContext('2d');
                new Chart(ctxCelular, { type: 'line', data: { labels: chartLabelsCelular, datasets: [{ label: 'Horas de uso', data: chartDataCelular, fill: false, borderColor: 'rgb(255, 99, 132)', tension: 0.1 }] }, options: { scales: { y: { beginAtZero: true, title: { display: true, text: 'Horas de Uso' } } }, plugins: { legend: { display: false } } } });
            }

            // --- Gráfico 3: Horas en Redes (Líneas) ---
            if (document.getElementById('redesChart')) {
                // ... (código del gráfico 3 sin cambios)
                const chartLabelsRedes = @Html.Raw(Json.Serialize(labelsRedesList));
                const chartDataRedes = @Html.Raw(Json.Serialize(dataRedesList));
                const ctxRedes = document.getElementById('redesChart').getContext('2d');
                new Chart(ctxRedes, { type: 'line', data: { labels: chartLabelsRedes, datasets: [{ label: 'Horas en redes', data: chartDataRedes, fill: false, borderColor: 'rgb(75, 192, 192)', tension: 0.1 }] }, options: { scales: { y: { beginAtZero: true, title: { display: true, text: 'Horas de Uso' } } }, plugins: { legend: { display: false } } } });
            }

            // ======================= INICIO: CÓDIGO PARA CREAR GRÁFICO DE ESTADOS =======================
            // --- Gráfico 4: Distribución de Estados (Doughnut) ---
            if (document.getElementById('estadosChart')) {
                const chartLabelsEstados = @Html.Raw(Json.Serialize(labelsEstadosList));
                const chartDataEstados = @Html.Raw(Json.Serialize(dataEstadosList));
                const ctxEstados = document.getElementById('estadosChart').getContext('2d');
                new Chart(ctxEstados, {
                    type: 'doughnut', // <-- Tipo de gráfico para porcentajes
                    data: {
                        labels: chartLabelsEstados, // ["Inhibido", "Exitado", "Otro"]
                        datasets: [{
                            label: 'Distribución de Estados',
                            data: chartDataEstados, // Los porcentajes calculados
                            backgroundColor: [
                                'rgba(255, 99, 132, 0.7)',  // Rojo para "Inhibido"
                                'rgba(75, 192, 192, 0.7)',  // Verde para "Exitado"
                                'rgba(201, 203, 207, 0.7)'  // Gris para "Otro"
                            ],
                            borderColor: [
                                'rgba(255, 99, 132, 1)',
                                'rgba(75, 192, 192, 1)',
                                'rgba(201, 203, 207, 1)'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                position: 'top', // La leyenda es útil en este tipo de gráfico
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        let label = context.label || '';
                                        if (label) {
                                            label += ': ';
                                        }
                                        if (context.parsed !== null) {
                                            label += context.parsed + '%'; // Añadir el símbolo de porcentaje
                                        }
                                        return label;
                                    }
                                }
                            }
                        }
                    }
                });
            }
            // ======================= FIN: CÓDIGO PARA CREAR GRÁFICO DE ESTADOS =======================
        });
    </script>
}