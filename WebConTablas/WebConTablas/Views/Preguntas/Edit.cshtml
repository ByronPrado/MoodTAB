@model Paciente

<h2>Editar Preguntas de @Model.Name</h2>

<table class="table">
    <thead>
        <tr>
            <th>Contenido</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pregunta in Model.Preguntas)
        {
            <tr>
                <td>
                    <form asp-action="UpdatePregunta" method="post">
                        <input type="hidden" name="Id" value="@pregunta.Id" />
                        <input type="hidden" name="IdPaciente" value="@Model.Id" />
                        <input type="text" name="Contenido" value="@pregunta.Contenido" class="form-control" />
                        <button type="submit" class="btn btn-success btn-sm mt-1">Guardar</button>
                    </form>
                </td>
                <td>
                    <form asp-action="DeletePregunta" method="post" onsubmit="return confirm('¿Deseas eliminar esta pregunta?');">
                        <input type="hidden" name="Id" value="@pregunta.Id" />
                        <input type="hidden" name="IdPaciente" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" asp-controller="Pacientes" class="btn btn-secondary">Volver</a>