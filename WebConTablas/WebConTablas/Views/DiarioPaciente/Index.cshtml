@model IEnumerable<DiarioPaciente>
@{
    ViewBag.Title = "Diarios del Paciente";
}

@using System.Text.Json
@functions {
    public List<string> GetTagValues(string tagsJson)
    {
        if (string.IsNullOrWhiteSpace(tagsJson))
            return new List<string>();

        try
        {
            var elements = JsonSerializer.Deserialize<List<Dictionary<string, string>>>(tagsJson);
            return elements?.Select(e => e.GetValueOrDefault("value") ?? "").ToList() ?? new List<string>();
        }
        catch
        {
            // Si falla la deserialización, intenta mostrar el string tal cual
            return new List<string> { tagsJson };
        }
    }
}

<h2>Diarios del Paciente</h2>

<a asp-action="Create" asp-route-idPaciente="@ViewBag.IdPaciente" class="btn btn-primary mb-3">Agregar Diario</a>

<a href="/Pacientes/Index" class="btn btn-secondary mb-3">Volver a Pacientes</a>


<table class="table">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Texto</th>
            <th>Emociones</th>
            <th>Pasos</th>
            <th>Horas Celular</th>
            <th>Desbloqueos</th>
            <th>Horas Redes</th>
            <th>Horas Sueño</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.Fecha.ToShortDateString()</td>
                <td>@d.Texto</td>
                <td>
                    @foreach (var tag in GetTagValues(d.Tags))
                    {
                        <div>@tag</div>
                    }
                </td>
                <td>@d.Pasos</td>
                <td>@d.HorasCelular</td>
                <td>@d.DesbloqueosCelular</td>
                <td>@d.HorasRedesSociales</td>
                <td>@d.HorasSueno</td>
            </tr>
        }
    </tbody>
</table>

