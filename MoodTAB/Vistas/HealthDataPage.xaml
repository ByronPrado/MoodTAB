<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoodTAB.Vistas.HealthDataPage"
             Title="HealthData">
    <VerticalStackLayout>      
        <Label Text="Health Connect Demo" FontSize="24" />
        <Button Text="Verificar Health Connect" Command="{Binding CheckClicked}"/>
        <Button Text="Pedir Permisos" Command="{Binding RequestPermissionsClicked}"/>
        <Button Text="Leer Pasos de Hoy" Command="{Binding ReadStepsClicked}"/>
        <Label x:Name="StepsLabel" Text="Pasos: ?" FontSize="18" />
    </VerticalStackLayout>
</ContentPage>